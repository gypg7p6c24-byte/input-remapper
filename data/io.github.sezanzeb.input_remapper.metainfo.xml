<component type="desktop-application">
  <id>io.github.sezanzeb.input_remapper</id>
  
  <name>Input Remapper</name>
  <summary>Remap Linux input devices, shortcuts, and macros</summary>
  
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>
  
  <supports>
    <control>pointing</control>
    <control>keyboard</control>
    <control>gamepad</control>
  </supports>
  
  <description>
    <p>
      Input Remapper remaps keyboards, mice, gamepads, and keypads on Linux.
      It supports X11 and Wayland, per-game presets, programmable macros,
      combined buttons, and non-keyboard inputs such as clicks, joysticks,
      and wheels.
    </p>
  </description>
  
  <launchable type="desktop-id">input-remapper-gtk.desktop</launchable>
  
  <screenshots>
    <screenshot type="default">
      <caption>Defining a new mapping</caption>
      <image>https://raw.githubusercontent.com/sezanzeb/input-remapper/main/readme/screenshot.png</image>
    </screenshot>
    <screenshot>
      <image>https://raw.githubusercontent.com/sezanzeb/input-remapper/main/readme/screenshot_2.png</image>
    </screenshot>
  </screenshots>
  
  <url type="homepage">https://github.com/gypg7p6c24-byte/input-remapper</url>
  <url type="bugtracker">https://github.com/gypg7p6c24-byte/input-remapper/issues</url>
  
